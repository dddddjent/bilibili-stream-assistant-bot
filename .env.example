# Copy to .env and fill in your bot token
# Create a bot + token via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Bilibili live room to check
BILIBILI_ROOM_ID=1990572299

# Polling interval (seconds)
CHECK_INTERVAL_SECONDS=20

# Optional: if set, bot will start sending messages on startup to this chat_id.
# You can get it by sending /start to the bot and reading the chat id from logs,
# or by using @userinfobot / @RawDataBot, etc.
TELEGRAM_CHAT_ID=
